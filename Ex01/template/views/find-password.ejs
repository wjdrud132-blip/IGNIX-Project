<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1280">
  <title>비밀번호 변경 - FIDS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{min-height:100vh;background:#f5f6fa;font-family:"Pretendard","Apple SD Gothic Neo",Arial,sans-serif;color:#10172f;display:flex;align-items:center;justify-content:center}
    .wrap{width:480px;background:#fff;border:1px solid #e5e7eb;border-radius:16px;box-shadow:0 18px 45px rgba(15,23,42,.08);padding:44px 48px}
    .brand{text-align:center;margin-bottom:30px}.brand h1{font-size:28px;font-weight:800;letter-spacing:.5px;color:#07112d}.brand span{display:block;width:32px;height:3px;background:#2563eb;border-radius:999px;margin:10px auto 14px}.brand p{font-size:13px;color:#9aa3b5;line-height:1.6}
    .icon{width:58px;height:58px;border-radius:50%;background:#eef4ff;color:#1d4ed8;display:flex;align-items:center;justify-content:center;margin:0 auto 20px}.icon i{font-size:28px}
    h2{font-size:22px;font-weight:800;text-align:center;margin-bottom:8px}.sub{text-align:center;color:#8a94a6;font-size:13px;margin-bottom:26px;line-height:1.6}
    .step{display:none}.step.active{display:block}.field{margin-bottom:16px}.field label{display:block;font-size:12px;font-weight:800;color:#374151;margin-bottom:7px}.input-wrap{position:relative}.input-wrap i{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:16px;color:#b9c1d1}.input-wrap input{width:100%;height:44px;border:1.5px solid #e5e7eb;border-radius:9px;background:#fafafa;padding:0 14px 0 40px;font-family:inherit;font-size:14px;outline:none}.input-wrap input:focus{background:#fff;border-color:#2563eb}.email-wrap input{padding-right:96px}.email-domain{position:absolute;right:0;top:0;height:44px;min-width:92px;display:flex;align-items:center;justify-content:center;background:#f1f3f7;border-left:1px solid #e5e7eb;border-radius:0 9px 9px 0;color:#6b7280;font-size:13px;font-weight:700}
    .btn{width:100%;height:48px;border:0;border-radius:9px;background:#111827;color:#fff;font-size:15px;font-weight:800;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px}.btn:hover{background:#0b1220}.link{text-align:center;margin-top:18px;font-size:13px;color:#9aa3b5}.link a{color:#2563eb;font-weight:800;text-decoration:none}.hint{margin-top:14px;border:1px solid #bfdbfe;background:#eff6ff;color:#1e40af;border-radius:9px;padding:12px;font-size:12px;line-height:1.5}.password-rules{font-size:12px;color:#16a34a;line-height:1.8;margin:4px 0 12px}.password-rules i{font-size:13px;margin-right:4px}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="brand"><h1>FIDS</h1><span></span><p>&#44277;&#44277; &#50416;&#47112;&#44592;&#53685; &#45236; &#54868;&#51116;&#47484; &#49892;&#49884;&#44036;&#51004;&#47196;<br>&#44048;&#51648;&#54616;&#44256; &#44288;&#47532;&#54616;&#45716; &#49828;&#47560;&#53944; &#54540;&#47019;&#54268;</p></div>
    <div class="icon"><i class="ti ti-key"></i></div>
    <h2>&#48708;&#48128;&#48264;&#54840; &#48320;&#44221;</h2>
    <p class="sub">&#44228;&#51221; &#51060;&#47700;&#51068; &#51064;&#51613; &#54980; &#49352; &#48708;&#48128;&#48264;&#54840;&#47484; &#49444;&#51221;&#54633;&#45768;&#45796;.</p>

    <section class="step active" id="stepEmail">
      <div class="field"><label>&#51060;&#47700;&#51068;</label><div class="input-wrap email-wrap"><i class="ti ti-mail"></i><input id="email_id" type="text" placeholder="&#51060;&#47700;&#51068;&#51012; &#51077;&#47141;&#54616;&#49464;&#50836;"><span class="email-domain">@korea.kr</span></div></div>
      <button class="btn" type="button" onclick="sendCode()"><i class="ti ti-send"></i>&#51064;&#51613;&#48264;&#54840; &#48156;&#49569;</button>
    </section>

    <section class="step" id="stepCode">
      <div class="field"><label>&#51064;&#51613;&#48264;&#54840;</label><div class="input-wrap"><i class="ti ti-shield-check"></i><input id="code" type="text" maxlength="6" placeholder="6&#51088;&#47532; &#51064;&#51613;&#48264;&#54840;"></div></div>
      <button class="btn" type="button" onclick="verifyCode()"><i class="ti ti-check"></i>&#51064;&#51613;&#54616;&#44592;</button>
    </section>

        <section class="step" id="stepPassword">
      <div class="field"><label>&#49352; &#48708;&#48128;&#48264;&#54840;</label><div class="input-wrap"><i class="ti ti-lock"></i><input id="new_pw" type="password" placeholder="8&#51088; &#51060;&#49345; &#51077;&#47141;"></div></div>
      <div class="password-rules"><div><i class="ti ti-circle-check"></i>8&#51088; &#51060;&#49345;</div><div><i class="ti ti-circle-check"></i>&#44592;&#51316; &#47196;&#44536;&#51064; &#48708;&#48128;&#48264;&#54840;&#47196; &#49324;&#50857;&#46121;&#45768;&#45796;.</div></div>
      <div class="field"><label>&#48708;&#48128;&#48264;&#54840; &#54869;&#51064;</label><div class="input-wrap"><i class="ti ti-lock-check"></i><input id="new_pw_check" type="password" placeholder="&#48708;&#48128;&#48264;&#54840;&#47484; &#54620; &#48264; &#45908; &#51077;&#47141;"></div></div>
      <button class="btn" type="button" onclick="resetPassword()"><i class="ti ti-refresh"></i>&#48708;&#48128;&#48264;&#54840; &#48320;&#44221;</button>
    </section>

    <div class="link"><a href="/login">&#47196;&#44536;&#51064; &#54868;&#47732;&#51004;&#47196; &#46028;&#50500;&#44032;&#44592;</a></div>
  </div>

  <script>
    let resetEmail = "";
    function fullEmail() {
      const value = document.getElementById("email_id").value.trim();
      return value.includes("@") ? value : value + "@korea.kr";
    }
    function showStep(id) {
      document.querySelectorAll(".step").forEach((step) => step.classList.remove("active"));
      document.getElementById(id).classList.add("active");
    }
    async function sendCode() {
      resetEmail = fullEmail();
      if (!resetEmail || resetEmail === "@korea.kr") return alert("\uC774\uBA54\uC77C\uC744 \uC785\uB825\uD574\uC8FC\uC138\uC694.");
      const res = await fetch("/manager/password/send-code", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ mgr_email: resetEmail }) });
      const result = await res.json();
      alert(result.message);
      if (result.success) showStep("stepCode");
    }
    async function verifyCode() {
      const code = document.getElementById("code").value.trim();
      if (!code) return alert("\uC778\uC99D\uBC88\uD638\uB97C \uC785\uB825\uD574\uC8FC\uC138\uC694.");
      const res = await fetch("/manager/password/verify-code", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ mgr_email: resetEmail, code }) });
      const result = await res.json();
      alert(result.message);
      if (result.success) showStep("stepPassword");
    }
    async function resetPassword() {
      const pw = document.getElementById("new_pw").value.trim();
      const pwCheck = document.getElementById("new_pw_check").value.trim();
      if (pw.length < 8) return alert("\uBE44\uBC00\uBC88\uD638\uB294 8\uC790 \uC774\uC0C1\uC73C\uB85C \uC785\uB825\uD574\uC8FC\uC138\uC694.");
      if (pw !== pwCheck) return alert("\uBE44\uBC00\uBC88\uD638\uAC00 \uC77C\uCE58\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.");
      const res = await fetch("/manager/password/reset", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ mgr_email: resetEmail, mgr_pw: pw }) });
      const result = await res.json();
      alert(result.message);
      if (result.success) location.href = "/login";
    }
  </script>
</body>
</html>
