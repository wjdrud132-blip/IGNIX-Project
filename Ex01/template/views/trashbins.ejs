  <style>
    *{box-sizing:border-box;margin:0;padding:0}body{font-family:Pretendard,"Apple SD Gothic Neo",Arial,sans-serif;background:#f5f6fa;display:flex;height:100vh;overflow:hidden;color:#111827}.sidebar{width:220px;background:#1a2235;display:flex;flex-direction:column;height:100vh;flex-shrink:0}.sb-logo{padding:20px 18px 16px;border-bottom:1px solid rgba(255,255,255,.08)}.sb-logo-title{font-size:16px;font-weight:800;color:#fff}.sb-logo-title span{display:inline-block;width:3px;height:16px;background:#2d6be4;border-radius:2px;margin-right:8px;vertical-align:middle}.sb-logo-sub{font-size:11px;color:rgba(255,255,255,.45);margin-top:4px}.sb-logo-sub2{font-size:10px;color:rgba(255,255,255,.35);margin-top:3px}.sb-nav{padding:14px 10px;flex:1}.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;font-size:13px;color:rgba(255,255,255,.62);cursor:pointer;margin-bottom:3px}.nav-item.active,.nav-item:hover{background:rgba(255,255,255,.1);color:#fff}.nav-item i{font-size:17px}.approval-badge{display:none;margin-left:auto;min-width:18px;height:18px;padding:0 5px;border-radius:999px;background:#ef4444;color:#fff;font-size:11px;align-items:center;justify-content:center}.sb-bottom{padding:14px 10px;border-top:1px solid rgba(255,255,255,.08)}.sb-user{display:flex;align-items:center;gap:10px;padding:10px 12px;margin-bottom:2px}.sb-avatar{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center}.sb-avatar i{font-size:15px;color:rgba(255,255,255,.75)}.sb-user-name{font-size:12px;font-weight:700;color:#fff}.sb-user-email{font-size:10px;color:rgba(255,255,255,.45);margin-top:1px}.sb-logout{display:flex;align-items:center;gap:10px;padding:9px 12px;font-size:13px;color:rgba(255,255,255,.48);cursor:pointer;border-radius:8px}.sb-logout:hover{color:#fff;background:rgba(255,255,255,.06)}.main{flex:1;display:flex;flex-direction:column;overflow:hidden}.topbar{height:60px;background:#fff;border-bottom:1px solid #e8e9ed;padding:0 28px;display:flex;align-items:center;justify-content:space-between}.topbar-title{font-size:20px;font-weight:800}.topbar-right{display:flex;align-items:center;gap:14px;font-size:12px;color:#64748b}.btn-add{height:36px;border:1px solid #bfd2f6;background:#eef5ff;color:#2563eb;border-radius:8px;padding:0 14px;font-weight:800;display:flex;align-items:center;gap:7px;cursor:pointer}.content{padding:20px 28px;overflow:auto}.stat-row{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:18px}.stat-card{background:#fff;border:1px solid #e0e6ef;border-radius:10px;padding:18px 22px;display:flex;justify-content:space-between;align-items:center;min-height:112px;cursor:pointer}.stat-card:hover{box-shadow:0 8px 22px rgba(15,23,42,.06)}.stat-label{font-size:13px;font-weight:800;margin-bottom:8px;color:#64748b}.stat-num{font-size:30px;font-weight:900}.stat-unit{font-size:16px;margin-left:4px;color:#475569}.stat-sub{font-size:12px;color:#94a3b8;margin-top:6px}.stat-icon{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px}.stat-card.total .stat-label,.stat-card.total .stat-num{color:#2563eb}.stat-card.total .stat-icon{background:#eaf2ff;color:#2563eb}.stat-card.danger .stat-label,.stat-card.danger .stat-num,.stat-card.danger .stat-sub{color:#ef4444}.stat-card.danger .stat-icon{background:#fee2e2;color:#ef4444}.stat-card.warn .stat-label,.stat-card.warn .stat-num,.stat-card.warn .stat-sub{color:#d97706}.stat-card.warn .stat-icon{background:#fef3c7;color:#d97706}.stat-card.good .stat-label,.stat-card.good .stat-num,.stat-card.good .stat-sub{color:#059669}.stat-card.good .stat-icon{background:#dcfce7;color:#059669}.stat-card.offline .stat-label,.stat-card.offline .stat-num{color:#64748b}.stat-card.offline .stat-icon{background:#f1f5f9;color:#64748b}.panel{background:#fff;border:1px solid #e0e6ef;border-radius:10px;overflow:hidden}.panel-head{height:58px;padding:0 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e9edf3}.panel-title{font-size:16px;font-weight:800}.filters{display:flex;gap:8px;align-items:center}.search-box{height:36px;width:260px;border:1px solid #d8e0ec;border-radius:8px;padding:0 12px;display:flex;align-items:center;gap:8px;color:#94a3b8}.search-box input{border:0;outline:0;width:100%;font-family:inherit}.sel{height:36px;border:1px solid #d8e0ec;border-radius:8px;background:#fff;padding:0 10px;font-family:inherit}table{width:100%;border-collapse:collapse;font-size:13px}th{height:42px;background:#f8fafc;color:#8a9ab3;text-align:left;font-weight:800;padding:0 18px;border-bottom:1px solid #e9edf3}td{height:62px;padding:0 18px;border-bottom:1px solid #eef2f7;vertical-align:middle}tbody tr.danger{background:#fff1f2;color:#ef4444}tbody tr.warning{background:#fffbeb;color:#d97706}tbody tr.offline{color:#64748b;background:#f8fafc}.id-cell{font-weight:900}.loc-main{font-weight:800;color:#111827}.loc-sub{font-size:11px;color:#8a9ab3;margin-top:4px}.badge{display:inline-flex;align-items:center;gap:4px;border-radius:999px;padding:5px 10px;font-size:12px;font-weight:800}.badge.danger{background:#fee2e2;color:#ef4444}.badge.warning{background:#fef3c7;color:#d97706}.badge.normal{background:#dcfce7;color:#059669}.badge.offline{background:#e2e8f0;color:#64748b}.action-cell{display:flex;gap:8px}.icon-btn{width:30px;height:30px;border:1px solid #d8e0ec;background:#fff;border-radius:7px;color:#2563eb;display:inline-flex;align-items:center;justify-content:center;cursor:pointer}.icon-btn.delete{color:#ef4444}.empty{padding:45px;text-align:center;color:#94a3b8}.alert-area{position:relative}.alert-button{width:40px;height:40px;border-radius:50%;border:1px solid #dde5f0;background:#fff;display:flex;align-items:center;justify-content:center;position:relative;cursor:pointer}.alert-button i{font-size:18px}.alert-dot{display:none;position:absolute;right:8px;top:7px;width:7px;height:7px;border-radius:50%;background:#ef4444}.alert-dropdown{display:none;position:absolute;right:0;top:48px;width:340px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;box-shadow:0 20px 45px rgba(15,23,42,.14);z-index:50;overflow:hidden}.alert-dropdown.open{display:block}.alert-head{height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid #edf2f7}.alert-head button,.alert-more{border:0;background:transparent;color:#2563eb;font-weight:800;cursor:pointer}.alert-list{max-height:320px;overflow:auto}.alert-item{display:flex;gap:12px;padding:14px 16px;border-bottom:1px solid #eef2f7}.alert-item.danger{background:#fff1f2}.alert-item.warning{background:#fffbeb}.alert-item-icon{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}.alert-item.danger .alert-item-icon{background:#fee2e2;color:#ef4444}.alert-item.warning .alert-item-icon{background:#fef3c7;color:#d97706}.alert-item-title{font-size:13px;font-weight:900}.alert-item.danger .alert-item-title{color:#ef4444}.alert-item.warning .alert-item-title{color:#d97706}.alert-item-text{font-size:12px;color:#64748b;margin-top:3px}.alert-more{width:100%;height:42px;border-top:1px solid #edf2f7;background:#fff}.modal-overlay,.all-alert-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:100;align-items:center;justify-content:center}.modal-overlay.open,.all-alert-overlay.open{display:flex}.modal,.detail-modal,.all-alert-modal{background:#fff;border-radius:14px;box-shadow:0 22px 55px rgba(15,23,42,.25);overflow:hidden}.modal.register{width:520px}.detail-modal{width:520px}.modal-head,.detail-head,.all-alert-header{height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 22px;border-bottom:1px solid #edf2f7}.modal-head button,.detail-head button,.all-alert-header button{border:0;background:transparent;font-size:22px;color:#94a3b8;cursor:pointer}.modal-body,.detail-body{padding:22px}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 16px}.form-grid .full{grid-column:1/3}.form-grid label{display:block;font-size:12px;font-weight:800;margin-bottom:8px;color:#475569}.form-grid input{width:100%;height:42px;border:1px solid #d8e0ec;border-radius:8px;padding:0 12px;font-family:inherit}.error{display:none;color:#ef4444;font-size:12px;margin-top:12px}.modal-actions{display:flex;gap:10px;margin-top:20px}.btn-cancel,.btn-save{height:44px;border-radius:8px;font-family:inherit;font-weight:900;cursor:pointer;flex:1}.btn-cancel{background:#fff;border:1px solid #d8e0ec;color:#475569}.btn-save{background:#1a2235;color:#fff;border:0}.detail-title-row{display:flex;justify-content:space-between;gap:12px;margin-bottom:18px}.detail-name{font-size:20px;font-weight:900;line-height:1.35}.detail-region{font-size:13px;color:#8a9ab3;margin-top:4px}.detail-status{height:30px;border-radius:999px;padding:0 14px;display:inline-flex;align-items:center;font-size:13px;font-weight:900}.detail-status.danger{background:#fee2e2;color:#ef4444}.detail-status.warning{background:#fef3c7;color:#d97706}.detail-status.normal{background:#dcfce7;color:#059669}.detail-status.offline{background:#e2e8f0;color:#64748b}.detail-info{display:grid;grid-template-columns:1fr 1fr;gap:16px 24px;background:#f8fafc;border-radius:10px;padding:18px}.detail-label{font-size:12px;color:#94a3b8;font-weight:800;margin-bottom:6px}.detail-value{font-size:14px;font-weight:900}.all-alert-modal{width:520px;max-height:680px}.all-alert-header{height:auto;padding:18px 22px}.all-alert-header h2{font-size:20px}.all-alert-header p{font-size:12px;color:#94a3b8;margin-top:4px}.all-alert-list{max-height:560px;overflow:auto;padding:8px}.trash-list{max-height:420px;overflow:auto}.trash-row{display:grid;grid-template-columns:70px 1fr 140px 130px;gap:12px;align-items:center;padding:16px;border-bottom:1px solid #edf2f7}.trash-row-title{font-weight:900}.trash-row-sub{font-size:12px;color:#64748b;margin-top:4px}.trash-actions{display:flex;gap:8px;justify-content:flex-end}.small-btn{height:32px;border-radius:7px;border:1px solid #d8e0ec;background:#fff;padding:0 10px;font-weight:800;cursor:pointer}.small-btn.restore{color:#2563eb}.small-btn.delete{color:#ef4444;border-color:#fecaca;background:#fff7f7}
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-title"><span></span>FIDS</div>
      <div class="sb-logo-sub2">쓰레기통 화재 감지 시스템</div>
      <div class="sb-logo-sub">관리자 대시보드</div>
    </div>
    <nav class="sb-nav">
      <div class="nav-item" onclick="location.href='/dashboard'"><i class="ti ti-home"></i>대시보드</div>
      <div class="nav-item active" onclick="location.href='/trashbins'"><i class="ti ti-trash"></i>쓰레기통 관리</div>
      <div class="nav-item" onclick="location.href='/realtime'"><i class="ti ti-chart-line"></i>실시간 모니터링</div>
      <div class="nav-item" onclick="location.href='/alert'"><i class="ti ti-bell"></i>알림 기록</div>
      <div class="nav-item operator-menu" onclick="location.href='/admin/approval'"><i class="ti ti-user-check"></i>관리자 승인 관리<span class="approval-badge" id="approvalBadge"></span></div>
      <div class="nav-item" onclick="location.href='/settings'"><i class="ti ti-settings"></i>설정</div>
      <div class="nav-item" onclick="location.href='/'"><i class="ti ti-home-2"></i>메인페이지</div>
    </nav>
    <div class="sb-bottom">
      <div class="sb-user">
        <div class="sb-avatar"><i class="ti ti-user"></i></div>
        <div><div id="userName" class="sb-user-name">관리자</div><div id="userEmail" class="sb-user-email">admin@korea.kr</div></div>
      </div>
      <div id="logoutBtn" class="sb-logout"><i class="ti ti-logout"></i>로그아웃</div>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="topbar-title">쓰레기통 관리</div>
      <div class="topbar-right">
        <i class="ti ti-calendar"></i><span id="nowText"></span>
        <div class="alert-area">
          <button class="alert-button" id="alertButton" type="button"><i class="ti ti-bell"></i><span class="alert-dot" id="alertDot"></span></button>
          <div class="alert-dropdown" id="alertDropdown">
            <div class="alert-head"><strong>알림</strong><button id="readAllBtn" type="button">모두 읽음</button></div>
            <div class="alert-list" id="alertList"></div>
            <button class="alert-more" id="openAllAlertsBtn" type="button">전체 알림 보기 →</button>
          </div>
        </div>
        <button class="btn-add" type="button" onclick="openRegisterModal()"><i class="ti ti-plus"></i>신규 등록</button>
      </div>
    </header>

    <section class="content">
      <div class="stat-row">
        <div class="stat-card total" onclick="filterByStatus('')"><div><div class="stat-label">전체 등록</div><div><span class="stat-num" id="totalCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">등록된 전체 개수</div></div><div class="stat-icon"><i class="ti ti-trash"></i></div></div>
        <div class="stat-card danger" onclick="filterByStatus('danger')"><div><div class="stat-label">위험 상태</div><div><span class="stat-num" id="dangerCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">즉시 대응 필요</div></div><div class="stat-icon"><i class="ti ti-flame"></i></div></div>
        <div class="stat-card warn" onclick="filterByStatus('warning')"><div><div class="stat-label">주의 상태</div><div><span class="stat-num" id="warningCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">모니터링 필요</div></div><div class="stat-icon"><i class="ti ti-alert-triangle"></i></div></div>
        <div class="stat-card good" onclick="filterByStatus('normal')"><div><div class="stat-label">정상 운영</div><div><span class="stat-num" id="normalCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">정상 상태</div></div><div class="stat-icon"><i class="ti ti-check"></i></div></div>
        <div class="stat-card offline" onclick="filterByStatus('offline')"><div><div class="stat-label">오프라인</div><div><span class="stat-num" id="offlineCount">0</span><span class="stat-unit">개</span></div><div class="stat-sub">연결 끊김</div></div><div class="stat-icon"><i class="ti ti-wifi-off"></i></div></div>
      </div>

      <div class="panel">
        <div class="panel-head">
          <span class="panel-title">등록된 쓰레기통 목록</span>
          <div class="filters">
            <div class="search-box"><i class="ti ti-search"></i><input id="searchInput" placeholder="쓰레기통 ID, 설치 위치 검색..." oninput="renderTable()"></div>
            <select class="sel" id="statusFilter" onchange="renderTable()">
              <option value="">전체 상태</option><option value="danger">위험</option><option value="warning">주의</option><option value="normal">정상</option><option value="offline">오프라인</option>
            </select>
          </div>
        </div>
        <table>
          <thead><tr><th>쓰레기통 ID</th><th>설치 위치</th><th>상태</th><th>설치일</th><th>관리자</th><th>관리</th></tr></thead>
          <tbody id="trashbinBody"></tbody>
        </table>
        <div class="empty" id="emptyText" style="display:none">등록된 쓰레기통이 없습니다.</div>
      </div>
    </section>
  </main>

  <div class="all-alert-overlay" id="allAlertOverlay"><div class="all-alert-modal"><div class="all-alert-header"><div><h2>전체 알림</h2><p>최근 감지된 알림 내역입니다.</p></div><button id="closeAllAlertsBtn" type="button">×</button></div><div class="all-alert-list" id="allAlertList"></div></div></div>

  <div class="modal-overlay" id="detailModal"><div class="detail-modal"><div class="detail-head"><strong>쓰레기통 상세보기</strong><button type="button" onclick="closeDetailModal()">×</button></div><div class="detail-body"><div class="detail-title-row"><div><div class="detail-name" id="detailName">-</div><div class="detail-region" id="detailRegion">-</div></div><span class="detail-status normal" id="detailStatus">정상</span></div><div class="detail-info"><div><div class="detail-label">설치 담당자</div><div class="detail-value" id="detailManager">-</div></div><div><div class="detail-label">연락처</div><div class="detail-value" id="detailPhone">-</div></div><div><div class="detail-label">설치일</div><div class="detail-value" id="detailInstalled">-</div></div><div><div class="detail-label">마지막 업데이트</div><div class="detail-value" id="detailUpdated">-</div></div><div><div class="detail-label">불꽃 감지</div><div class="detail-value" id="detailFlame">X</div></div><div><div class="detail-label">통신</div><div class="detail-value" id="detailNetwork">-</div></div></div><div class="modal-actions"><button class="btn-cancel" type="button" onclick="closeDetailModal()">닫기</button></div></div></div></div>

  <div class="modal-overlay" id="registerModal"><div class="modal register"><div class="modal-head"><strong>신규 등록</strong><button type="button" onclick="closeRegisterModal()">×</button></div><div class="modal-body"><div class="form-grid"><div><label>쓰레기통 ID</label><input id="binDisplayId" placeholder="예) #09"></div><div><label>설치 위치명</label><input id="binPlaceName" placeholder="예) 공원 입구"></div><div><label>시/도</label><input id="binCity" placeholder="예) 광주광역시"></div><div><label>구/군</label><input id="binDistrict" placeholder="예) 동구"></div><div><label>설치 담당자</label><input id="managerNameInput" placeholder="이름 입력"></div><div><label>연락처</label><input id="managerPhoneInput" placeholder="010-0000-0000"></div><div class="full"><label>설치일</label><input id="installedAt" type="date"></div></div><input id="networkStatus" type="hidden" value="1"><div class="error" id="formError"></div><div class="modal-actions"><button class="btn-cancel" type="button" onclick="closeRegisterModal()">취소</button><button class="btn-save" type="button" onclick="createTrashbin()">등록하기</button></div></div></div></div>

  <div class="modal-overlay" id="trashModal"><div class="modal" style="width:680px"><div class="modal-head"><strong>휴지통</strong><button type="button" onclick="closeTrashModal()">×</button></div><div class="modal-body"><p style="font-size:13px;color:#64748b;margin-bottom:12px">휴지통에서 삭제하면 쓰레기통이 완전히 삭제됩니다.</p><div class="trash-list" id="trashList"></div><div class="modal-actions"><button class="btn-cancel" type="button" onclick="closeTrashModal()">닫기</button></div></div></div></div>

<script>
const $=id=>document.getElementById(id);let trashbins=[];let currentStatus="";let alerts=[];let currentDetailTrashbinId=null;
const statusText=s=>s==="danger"?"위험":s==="warning"?"주의":s==="offline"?"오프라인":"정상";
const statusIcon=s=>s==="danger"?"ti-flame":s==="warning"?"ti-alert-triangle":s==="offline"?"ti-wifi-off":"ti-check";
function displayBinId(row){return String(row.display_bin_id||row.bin_id||"").replace(/^#/,'').padStart(2,"0")}
function fdate(v){if(!v)return"-";const d=new Date(v);if(!Number.isFinite(d.getTime()))return"-";return `${d.getFullYear()}. ${String(d.getMonth()+1).padStart(2,"0")}. ${String(d.getDate()).padStart(2,"0")}.`}
function ftime(v){if(!v)return"-";const d=new Date(v);if(!Number.isFinite(d.getTime()))return"-";return d.toLocaleTimeString("ko-KR",{hour:"2-digit",minute:"2-digit",second:"2-digit",hour12:false})}
function region(loc){if(!loc)return"-";const p=String(loc).split(/\s+/);return p.slice(0,2).join(" ")||loc}
function statusOf(r){if(String(r.sensor_online)==="N"||Number(r.network_status)===0)return"offline";if(r.alert_type==="danger")return"danger";if(r.alert_type==="warning")return"warning";return"normal"}
function parseFlame(r){const v=r.flame_value;return Number(v)===1||String(v).toUpperCase()==="O"?"O":"X"}
function networkText(r){return statusOf(r)==="offline"?"Wi-Fi 연결 끊김":"Wi-Fi 연결"}
function tick(){const n=new Date();$("nowText").textContent=n.toLocaleDateString("ko-KR",{year:"numeric",month:"2-digit",day:"2-digit",weekday:"short"})+" "+n.toLocaleTimeString("ko-KR",{hour:"2-digit",minute:"2-digit",second:"2-digit",hour12:false})}
function setUser(){const name=sessionStorage.getItem("name")||sessionStorage.getItem("mgr_name")||(sessionStorage.getItem("role")==="operator"?"운영자":"관리자");const email=sessionStorage.getItem("email")||sessionStorage.getItem("mgr_email")||"admin@korea.kr";$("userName").textContent=name;$("userEmail").textContent=email;document.querySelectorAll(".operator-menu").forEach(el=>el.style.display=sessionStorage.getItem("role")==="operator"?"flex":"none")}
async function loadTrashbins(){try{const r=await fetch("/trashbins/list",{cache:"no-store"});trashbins=await r.json();if(!Array.isArray(trashbins))trashbins=[];renderStats();renderTable()}catch(e){console.error(e);trashbins=[];renderStats();renderTable()}}
function renderStats(){const counts={danger:0,warning:0,normal:0,offline:0};trashbins.forEach(r=>counts[statusOf(r)]++);$("totalCount").textContent=trashbins.length;$("dangerCount").textContent=counts.danger;$("warningCount").textContent=counts.warning;$("normalCount").textContent=counts.normal;$("offlineCount").textContent=counts.offline}
function filterByStatus(s){currentStatus=s;$("statusFilter").value=s;renderTable()}
function renderTable(){const q=($("searchInput").value||"").toLowerCase();const s=$("statusFilter").value||currentStatus;let rows=trashbins.filter(r=>{const text=(`#${displayBinId(r)} ${r.bin_loc||""}`).toLowerCase();return(!q||text.includes(q))&&(!s||statusOf(r)===s)});const body=$("trashbinBody");body.innerHTML=rows.map(r=>{const st=statusOf(r);return `<tr class="${st}"><td class="id-cell">#${displayBinId(r)}</td><td><div class="loc-main">${r.bin_loc||"위치 미등록"}</div><div class="loc-sub">${region(r.bin_loc)}</div></td><td><span class="badge ${st}"><i class="ti ${statusIcon(st)}"></i>${statusText(st)}</span></td><td>${fdate(r.installed_at)}</td><td>${r.mgr_name||"관리자"}</td><td><div class="action-cell"><button class="icon-btn" type="button" title="상세보기" onclick="openDetailModal(${Number(r.bin_id)})"><i class="ti ti-eye"></i></button><button class="icon-btn delete" type="button" title="휴지통으로 이동" onclick="deleteTrashbin(${Number(r.bin_id)})"><i class="ti ti-trash"></i></button></div></td></tr>`}).join("");$("emptyText").style.display=rows.length?"none":"block"}
function openDetailModal(id){currentDetailTrashbinId=id;const r=trashbins.find(x=>Number(x.bin_id)===Number(id));if(!r)return;const st=statusOf(r);$("detailName").textContent=`#${displayBinId(r)} — ${r.bin_loc||"위치 미등록"}`;$("detailRegion").textContent=region(r.bin_loc);$("detailStatus").className="detail-status "+st;$("detailStatus").textContent=statusText(st);$("detailManager").textContent=r.mgr_name||"관리자";$("detailPhone").textContent=r.mgr_phone||"-";$("detailInstalled").textContent=fdate(r.installed_at);$("detailUpdated").textContent=st==="offline"?"-":ftime(r.sensor_created_at||r.alerted_at);$("detailFlame").textContent=st==="offline"?"-":parseFlame(r);$("detailNetwork").textContent=networkText(r);$("detailModal").classList.add("open")}
function closeDetailModal(){$("detailModal").classList.remove("open")}
function openRegisterModal(){$("registerModal").classList.add("open")}
function closeRegisterModal(){$("registerModal").classList.remove("open");$("formError").style.display="none";[binDisplayId,binPlaceName,binCity,binDistrict,managerNameInput,managerPhoneInput,installedAt].forEach(el=>el.value="")}
async function createTrashbin(){const city=binCity.value.trim(),district=binDistrict.value.trim(),place=binPlaceName.value.trim(),displayId=binDisplayId.value.trim();if(!displayId||!city||!district||!place||!installedAt.value){$("formError").textContent="쓰레기통 ID, 설치 위치명, 시/도, 구/군, 설치일을 입력해주세요.";$("formError").style.display="block";return}const binLoc=`${city} ${district} ${place}`;const mgrId=sessionStorage.getItem("user_id")||sessionStorage.getItem("mgr_id")||"";const r=await fetch("/trashbins",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({bin_id:displayId,bin_loc:binLoc,installed_at:installedAt.value,mgr_id:mgrId,network_status:networkStatus.value,manager_name:managerNameInput.value.trim(),manager_phone:managerPhoneInput.value.trim()})});const j=await r.json().catch(()=>({}));if(!r.ok){$("formError").textContent=j.message||"등록 실패";$("formError").style.display="block";return}closeRegisterModal();loadTrashbins()}
async function deleteTrashbin(id){if(!confirm("해당 쓰레기통을 휴지통으로 이동할까요?"))return;const r=await fetch(`/trashbins/${id}`,{method:"DELETE"});const j=await r.json().catch(()=>({}));if(!r.ok){alert(j.message||"휴지통 이동 실패");return}alert("휴지통으로 이동했습니다.");loadTrashbins()}
async function openTrashModal(){const r=await fetch("/trashbins/trash/list",{cache:"no-store"});const rows=await r.json().catch(()=>[]);$("trashList").innerHTML=Array.isArray(rows)&&rows.length?rows.map(x=>`<div class="trash-row"><strong>#${displayBinId(x)}</strong><div><div class="trash-row-title">${x.bin_loc||"위치 미등록"}</div><div class="trash-row-sub">관리자: ${x.mgr_name||"-"}</div></div><div>${fdate(x.installed_at)}</div><div class="trash-actions"><button class="small-btn restore" onclick="restoreTrashbin(${Number(x.bin_id)})">복구</button><button class="small-btn delete" onclick="hardDeleteTrashbin(${Number(x.bin_id)})">삭제</button></div></div>`).join(""):'<div class="empty">휴지통이 비어 있습니다.</div>';$("trashModal").classList.add("open")}
function closeTrashModal(){$("trashModal").classList.remove("open")}
async function restoreTrashbin(id){const r=await fetch(`/trashbins/trash/${id}/restore`,{method:"PATCH"});const j=await r.json().catch(()=>({}));alert(j.message||"복구되었습니다.");openTrashModal();loadTrashbins()}
async function hardDeleteTrashbin(id){if(!confirm("쓰레기통이 완전히 삭제됩니다. 계속할까요?"))return;const r=await fetch(`/trashbins/trash/${id}`,{method:"DELETE"});const j=await r.json().catch(()=>({}));alert(j.message||"삭제되었습니다.");openTrashModal();loadTrashbins()}
async function loadAlerts(){try{const r=await fetch("/alerts/topbar",{cache:"no-store"});alerts=await r.json();if(!Array.isArray(alerts))alerts=[]}catch(e){alerts=[]}renderAlerts()}
function alertTime(v){return ftime(v)}
function renderAlerts(){const unread=alerts.some(a=>a.is_received!=="Y");$("alertDot").style.display=unread?"block":"none";const danger=alerts.filter(a=>a.alert_type==="danger"||a.alert_type==="warning").slice(0,5);const html=danger.length?danger.map(a=>`<div class="alert-item ${a.alert_type}"><div class="alert-item-icon"><i class="ti ${statusIcon(a.alert_type)}"></i></div><div style="flex:1"><div class="alert-item-title">${a.alert_type==="danger"?"위험 감지":"주의 감지"}</div><div class="alert-item-text">#${String(a.bin_id).padStart(2,"0")} ${a.bin_loc||"위치 미등록"}</div><div class="alert-item-text">${a.alert_msg||"센서 알림"}</div></div><div class="alert-item-text">${alertTime(a.alerted_at)}</div></div>`).join(""):'<div class="empty">표시할 알림이 없습니다.</div>';$("alertList").innerHTML=html;$("allAlertList").innerHTML=html}
async function readAllAlerts(){await fetch("/alerts/read-all",{method:"POST"});await loadAlerts()}
function initEvents(){$("alertButton").onclick=e=>{e.stopPropagation();$("alertDropdown").classList.toggle("open")};$("readAllBtn").onclick=readAllAlerts;$("openAllAlertsBtn").onclick=()=>{$("alertDropdown").classList.remove("open");$("allAlertOverlay").classList.add("open")};$("closeAllAlertsBtn").onclick=()=>$("allAlertOverlay").classList.remove("open");document.onclick=e=>{if(!e.target.closest(".alert-area"))$("alertDropdown").classList.remove("open")};$("logoutBtn").onclick=()=>{sessionStorage.clear();alert("로그아웃되었습니다.");location.replace("/")}}
async function loadApprovalBadge(){if(sessionStorage.getItem("role")!=="operator")return;try{const r=await fetch("/admin/managers",{cache:"no-store"});const rows=await r.json();const count=Array.isArray(rows)?rows.filter(x=>Number(x.is_approved)===0||x.approval_status==="pending").length:0;const b=$("approvalBadge");if(count>0){b.textContent=count;b.style.display="inline-flex"}}catch(e){}}
setUser();initEvents();tick();setInterval(tick,1000);loadTrashbins();loadAlerts();loadApprovalBadge();setInterval(loadTrashbins,3000);setInterval(loadAlerts,5000);
</script>
<script src="/js/fire-alert.js"></script>
<script src="/js/topbar-alert.js"></script>
<script>window.addEventListener("pageshow",function(){if(!sessionStorage.getItem("role")){location.replace("/")}});</script>
</body>
</html>

