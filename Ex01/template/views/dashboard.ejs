      location.replace("/");
    });

    let dashboardCurrentFilter = "all";
    let dashboardBins = [];

    function filterTable(type, btn) {
      dashboardCurrentFilter = type;
      document.querySelectorAll(".ft-btn").forEach((button) => { button.className = "ft-btn"; });
      if (type === "all") btn.className = "ft-btn active-all";
      else if (type === "danger") btn.className = "ft-btn active-danger";
      else if (type === "warn") btn.className = "ft-btn active-warn";
      else if (type === "good") btn.className = "ft-btn active-good";
      renderDistrictMap(dashboardBins, dashboardCurrentFilter);
    }
    function openAllAlerts() {
      document.getElementById("alertDropdown").classList.remove("open");
      document.getElementById("allAlertOverlay").classList.add("open");
    }

    const alertButton = document.getElementById("alertButton");
    const alertDropdown = document.getElementById("alertDropdown");
    const readAllBtn = document.getElementById("readAllBtn");
    const alertDot = document.getElementById("alertDot");
    const openAllAlertsBtn = document.getElementById("openAllAlertsBtn");
    const sideOpenAllAlerts = document.getElementById("sideOpenAllAlerts");
    const allAlertOverlay = document.getElementById("allAlertOverlay");
    const closeAllAlertsBtn = document.getElementById("closeAllAlertsBtn");

    alertButton.addEventListener("click", (event) => {
      event.stopPropagation();
      alertDropdown.classList.toggle("open");
    });

    readAllBtn.addEventListener("click", async () => {
      fidsMarkAlertsRead();
      await fetch("/alerts/read-all", { method: "POST" });
      await loadDashboardData();
    });

    openAllAlertsBtn.addEventListener("click", openAllAlerts);
    sideOpenAllAlerts.addEventListener("click", openAllAlerts);

    closeAllAlertsBtn.addEventListener("click", () => {
      allAlertOverlay.classList.remove("open");
    });

    allAlertOverlay.addEventListener("click", (event) => {
      if (event.target === allAlertOverlay) {
        allAlertOverlay.classList.remove("open");
      }
    });

    document.addEventListener("click", (event) => {
      if (!event.target.closest(".alert-area")) {
        alertDropdown.classList.remove("open");
      }
    });

    const params = new URLSearchParams(location.search);
    const binId = params.get("bin_id");
    if (binId) {
      const target = document.getElementById("bin-" + binId);
      if (target) {
        target.classList.add("focus-bin");
        target.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    }
  </script>
  <script>
    function dashboardStatusOf(row) {
      if (row.alert_type === "danger") return "danger";
      if (row.alert_type === "warning") return "warn";
      return "good";
    }

    function dashboardFallbackSensorValues(row) {
      const id = Number(row.bin_id);
      const dangerMap = { 1: [68.7, 350], 2: [68.7, 350], 3: [66.4, 328], 4: [64.9, 305], 10: [67.5, 320] };
      const warningMap = { 5: [45.2, 120], 6: [43.5, 110], 7: [44.8, 108], 8: [44.6, 115] };
      const normalMap = { 9: [29.1, 18], 11: [30.2, 15], 12: [26.9, 8] };
      const values = dangerMap[id] || warningMap[id] || normalMap[id] || (row.alert_type === "danger" ? [68.7, 350] : row.alert_type === "warning" ? [45.2, 120] : [28.4, 12]);
      return { temp: values[0], smoke: values[1], flame: row.alert_type === "danger" ? 1 : 0 };
    }

    function dashboardParseSmoke(row) {
      const match = String(row.alert_msg || "").match(/\uC5F0\uAE30\s*\uAC10\uC9C0\uAC12\s*(\d+)/);
      return row.smoke_value ?? (match ? Number(match[1]) : dashboardFallbackSensorValues(row).smoke);
    }

    function dashboardParseTemp(row) {
      const match = String(row.alert_msg || "").match(/\uC628\uB3C4\s*([0-9.]+)/);
      return row.temp_value ?? (match ? Number(match[1]) : dashboardFallbackSensorValues(row).temp);
    }

    function dashboardParseFlame(row) {
      if (row.alert_type === "danger") return "O";
      const match = String(row.alert_msg || "").match(/\uBD88\uAF43\s*\uAC10\uC9C0\s*(0|1)/);
      const value = row.flame_value ?? (match ? Number(match[1]) : dashboardFallbackSensorValues(row).flame);
      return value === 1 ? "O" : "X";
    }

    function dashboardAlertTimestamp(value) {
      if (!value) return 0;
      if (value instanceof Date) return value.getTime();
      const raw = String(value).trim();
      const direct = new Date(raw);
      if (!Number.isNaN(direct.getTime())) return direct.getTime();
      const normalized = raw.replace(/\./g, "-").replace(/\s+/g, " ");
      const parsed = new Date(normalized);
      if (!Number.isNaN(parsed.getTime())) return parsed.getTime();
      const numbers = raw.match(/\d+/g) || [];
      if (numbers.length >= 3) {
        const year = Number(numbers[0]);
        const month = Number(numbers[1]) - 1;
        const day = Number(numbers[2]);
        const hour = Number(numbers[3] || 0);
        const minute = Number(numbers[4] || 0);
        const second = Number(numbers[5] || 0);
        return new Date(year, month, day, hour, minute, second).getTime();
      }
      return 0;
    }

    function dashboardTime(value) {
      if (!value) return "-";
      const timestamp = dashboardAlertTimestamp(value);
      if (!timestamp) return "-";
      const date = new Date(timestamp);
      const dateText = date.toLocaleDateString("ko-KR", { year: "numeric", month: "2-digit", day: "2-digit" }).replace(/\.\s?/g, ".").replace(/\.$/, "");
      const timeText = date.toLocaleTimeString("ko-KR", { hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false });
      return dateText + "<br>" + timeText;
    }

    function dashboardAiSummary(row, status) {
      const aiLabel = status === "danger" ? "\uC704\uD5D8" : status === "warn" ? "\uC8FC\uC758" : "\uC815\uC0C1";
      const rule = row.rule_status ? (row.rule_status === "danger" ? "\uC704\uD5D8" : row.rule_status === "warning" ? "\uC8FC\uC758" : "\uC815\uC0C1") : aiLabel;
      const confidence = row.ai_confidence != null ? ` \u00B7 ${row.ai_confidence}%` : "";
      return `\uAE30\uC874 ${rule} \u2192 AI ${aiLabel}${confidence}`;
    }

    function dashboardAlertTitle(type) {
      if (type === "danger") return "위험 감지";
      if (type === "warning") return "주의 감지";
      return "정상 복귀";
    }

    function dashboardAlertIcon(type) {
      if (type === "danger") return "ti-flame";
      if (type === "warning") return "ti-alert-triangle";
      return "ti-check";
    }

    function dashboardDistrictOf(row) {
      const loc = String(row.bin_loc || "").trim();
      const parts = loc.split(/\s+/);
      const gwangjuDistricts = ["동구", "남구", "북구", "광산구", "서구"];
      const matched = gwangjuDistricts.find((district) => parts.includes(district) || loc.includes("광주광역시 " + district) || loc.includes("광주시 " + district));
      if (matched) return matched;
      const anyGu = parts.find((part) => part.endsWith("구"));
      return anyGu || "기타";
    }

    function dashboardDistrictStatus(item) {
      if (item.danger > 0) return "danger";
      if (item.warn > 0) return "warn";
      return "good";
    }

    function dashboardDistrictLabel(status) {
      if (status === "danger") return "\uC704\uD5D8";
      if (status === "warn") return "\uC8FC\uC758";
      return "\uC815\uC0C1";
    }

    function renderDistrictMap(bins, filterType = "all") {
      const map = {};
      const visibleBins = filterType === "all"
        ? bins
        : bins.filter((row) => dashboardStatusOf(row) === filterType);

      visibleBins.forEach((row) => {
        const district = dashboardDistrictOf(row);
        if (!map[district]) map[district] = { name: district, total: 0, danger: 0, warn: 0, good: 0, samples: [] };
        const item = map[district];
        const status = dashboardStatusOf(row);
        item.total += 1;
        if (status === "danger") item.danger += 1;
        else if (status === "warn") item.warn += 1;
        else item.good += 1;
        item.samples.push(row);
      });

      const rank = (item) => item.danger > 0 ? 1 : item.warn > 0 ? 2 : 3;
      const rows = Object.values(map).sort((a, b) => rank(a) - rank(b) || b.danger - a.danger || b.warn - a.warn || b.total - a.total || a.name.localeCompare(b.name, "ko-KR"));
      const target = document.getElementById("districtMap");
      if (!rows.length) {
        const emptyText = filterType === "danger" ? "위험 상태의 쓰레기통이 없습니다." : filterType === "warn" ? "주의 상태의 쓰레기통이 없습니다." : filterType === "good" ? "정상 상태의 쓰레기통이 없습니다." : "표시할 쓰레기통 데이터가 없습니다.";
        target.innerHTML = '<div class="district-empty">' + emptyText + '</div>';
        return;
      }

      target.innerHTML = rows.map((item) => {
        const status = filterType === "all" ? dashboardDistrictStatus(item) : filterType;
        const iconType = status === "warn" ? "warning" : status;
        const top = item.samples.find((row) => dashboardStatusOf(row) === status) || item.samples[0];
        const counts = filterType === "all"
          ? '<span class="d">위험 <b>' + item.danger + '</b></span><span class="w">주의 <b>' + item.warn + '</b></span><span class="g">정상 <b>' + item.good + '</b></span><span>전체 <b>' + item.total + '</b></span>'
          : '<span class="' + (status === "danger" ? "d" : status === "warn" ? "w" : "g") + '">' + dashboardDistrictLabel(status) + ' <b>' + item.total + '</b></span>';
        const locationHtml = '<div class="district-locations">' + item.samples.slice(0, 3).map((row) => '<div class="district-location"><b>#' + String(row.bin_id).padStart(2, "0") + '</b><span>' + (row.bin_loc || "-") + '</span></div>').join("") + (item.samples.length > 3 ? '<div class="district-location-more">외 ' + (item.samples.length - 3) + '개 더 보기</div>' : '') + '</div>';
        return '<div class="district-card ' + status + '" data-status="' + status + '" onclick="location.href=\'/realtime?gun=' + encodeURIComponent(item.name) + '&status=' + encodeURIComponent(status) + '\'">' +
          '<div class="district-card-head"><div class="district-name">' + item.name + '</div><span class="district-badge ' + status + '"><i class="ti ' + dashboardAlertIcon(iconType) + '"></i>' + dashboardDistrictLabel(status) + '</span></div>' +
          '<div class="district-counts">' + counts + '</div>' +
          locationHtml +
        '</div>';
      }).join("");
    }

    function renderDashboardRecentAlerts(sourceRows) {
      const list = document.querySelector(".side-alert-list");
      if (!list) return;

      const escapeHtml = (value) => String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");

      const rowId = (row) => {
        const value = row.display_bin_id || row.bin_id || row.sensor_id || "";
        const number = String(value).replace(/[^0-9]/g, "");
        return number ? number.padStart(2, "0") : String(value || "-");
      };

      const rowTimestamp = (row) => {
        const raw = row.alerted_at || row.last_updated_at || row.updated_at || row.created_at || row.installed_at || "";
        const parsed = new Date(raw);
        if (!Number.isNaN(parsed.getTime())) return parsed.getTime();
        const nums = String(raw).match(/\d+/g) || [];
        if (nums.length >= 3) {
          return new Date(Number(nums[0]), Number(nums[1]) - 1, Number(nums[2]), Number(nums[3] || 0), Number(nums[4] || 0), Number(nums[5] || 0)).getTime();
        }
        return 0;
      };

      const rowTime = (row) => {
        const timestamp = rowTimestamp(row);
        if (!timestamp) return "-";
        const date = new Date(timestamp);
        const dateText = date.toLocaleDateString("ko-KR", { year: "numeric", month: "2-digit", day: "2-digit" })
          .replace(/\.\s?/g, ".")
          .replace(/\.$/, "");
        const timeText = date.toLocaleTimeString("ko-KR", { hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false });
        return dateText + "<br>" + timeText;
      };

      const rows = (Array.isArray(sourceRows) ? sourceRows : [])
        .filter((row) => row && (row.alert_type === "danger" || row.alert_type === "warning"))
        .sort((a, b) => rowTimestamp(b) - rowTimestamp(a) || Number(a.bin_id || 0) - Number(b.bin_id || 0))
        .slice(0, 5);

      if (!rows.length) {
        list.innerHTML = '<div class="empty" style="padding:24px 0">??? ??/?? ??? ????.</div>';
        return;
      }

      list.innerHTML = rows.map((row) => {
        const isDanger = row.alert_type === "danger";
        const kind = isDanger ? "d" : "w";
        const icon = isDanger ? "ti-flame" : "ti-alert-triangle";
        const title = isDanger ? "\uC704\uD5D8 \uAC10\uC9C0" : "\uC8FC\uC758 \uAC10\uC9C0";
        let message = row.alert_msg || (isDanger ? "\uD654\uC7AC \uC704\uD5D8 \uAC10\uC9C0 - \uC989\uAC01 \uB300\uC751 \uD544\uC694" : "\uC628\uB3C4 \uBC0F \uC5F0\uAE30 \uC784\uACC4\uAC12 \uCD08\uACFC");
        message = String(message)
          .replace(/\uBD88\uAF43\s*\uAC10\uC9C0\s*1/g, "\uBD88\uAF43 \uAC10\uC9C0 O")
          .replace(/\uBD88\uAF43\s*\uAC10\uC9C0\s*0/g, "\uBD88\uAF43 \uAC10\uC9C0 X");
        return '<div class="side-alert-item">' +
          '<div class="adot ' + kind + '"><i class="ti ' + icon + '"></i></div>' +
          '<div style="flex:1;min-width:0">' +
            '<div class="at ' + kind + '">' + title + '</div>' +
            '<div class="aloc">#' + rowId(row) + ' ' + escapeHtml(row.bin_loc || '') + '</div>' +
            '<div class="adesc">' + escapeHtml(message) + '</div>' +
          '</div>' +
          '<div class="atime">' + rowTime(row) + '</div>' +
        '</div>';
      }).join('');
    }

    let dashboardLastRefreshAt = new Date();
    async function loadDashboardData() {
      dashboardLastRefreshAt = new Date();
      const binResponse = await fetch("/trashbins/list");
      const alertResponse = await fetch("/alerts/list");
      const bins = await binResponse.json();
      let alerts = await alertResponse.json();
      alerts = fidsApplyAlertReadState(alerts);
      const sortRank = (type) => type === "danger" ? 1 : type === "warning" ? 2 : type === "normal" ? 3 : 4;
      bins.sort((a, b) => sortRank(a.alert_type) - sortRank(b.alert_type) || Number(a.bin_id) - Number(b.bin_id));
      alerts.sort((a, b) => sortRank(a.alert_type) - sortRank(b.alert_type) || Number(a.bin_id) - Number(b.bin_id));
      alertDot.classList.toggle("hide", !alerts.some((alert) => alert.alert_type === "danger" && alert.is_received !== "Y"));
      const danger = bins.filter((row) => row.alert_type === "danger").length;
      const warn = bins.filter((row) => row.alert_type === "warning").length;
      const good = bins.length - danger - warn;
      const statNums = document.querySelectorAll(".stat-num");

      statNums[0].textContent = bins.length;
      statNums[1].textContent = danger;
      statNums[2].textContent = warn;
      statNums[3].textContent = good;
      document.querySelector(".danger .stat-pct").textContent = bins.length ? ((danger / bins.length) * 100).toFixed(1) + "%" : "0%";
      document.querySelector(".warn .stat-pct").textContent = bins.length ? ((warn / bins.length) * 100).toFixed(1) + "%" : "0%";
      document.querySelector(".good .stat-pct").textContent = bins.length ? ((good / bins.length) * 100).toFixed(1) + "%" : "0%";

      dashboardBins = bins;
      document.querySelector(".district-dashboard").classList.add("compact");
      renderDistrictMap(dashboardBins, dashboardCurrentFilter);
      renderDashboardRecentAlerts(alerts);

      document.querySelector(".alert-dropdown .alert-list").innerHTML = alerts.filter((alert) => alert.alert_type === "danger").slice(0, 5).map((alert) => {
        const type = alert.alert_type === "normal" ? "success" : alert.alert_type;
        return `<div class="alert-item ${type} ${alert.is_received === "Y" ? "read" : ""}"><div class="alert-icon"><i class="ti ${dashboardAlertIcon(alert.alert_type)}"></i></div><div class="alert-text"><strong>${dashboardAlertTitle(alert.alert_type)}</strong><span>#${displayBinId(alert)} ${alert.bin_loc || ""}</span><small>${alert.alert_msg || "센서 상태 정상"}</small></div><span class="alert-time">${dashboardTime(alert.alerted_at)}</span></div>`;
      }).join("");

      document.querySelector(".all-alert-list").innerHTML = alerts.filter((alert) => alert.alert_type === "danger").map((alert) => {
        const type = alert.alert_type === "normal" ? "success" : alert.alert_type;
        return `<div class="all-alert-row ${type} ${alert.is_received === "Y" ? "read" : ""}"><div><strong>${dashboardAlertTitle(alert.alert_type)}</strong><span>#${displayBinId(alert)} ${alert.bin_loc || ""}</span></div><p>${alert.alert_msg || "센서 상태 정상"}</p><time>${dashboardTime(alert.alerted_at)}</time></div>`;
      }).join("");

      const params = new URLSearchParams(location.search);
      const binId = params.get("bin_id");
      if (binId) {
        const target = document.getElementById("bin-" + binId);
        if (target) {
          target.classList.add("focus-bin");
          target.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      }
    }

    loadDashboardData();
  </script>
  <script src="/js/fire-alert.js"></script>
  <script src="/js/topbar-alert.js"></script>
<script>document.querySelectorAll(".operator-menu").forEach((item)=>{item.style.display=sessionStorage.getItem("role")==="operator"?"flex":"none";});</script>
<script>
  window.addEventListener("pageshow", function () {
    if (!sessionStorage.getItem("role")) {
      location.replace("/");
    }
  });
</script>
</body>
</html>
























