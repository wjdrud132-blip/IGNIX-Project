*{box-sizing:border-box;margin:0;padding:0}body{font-family:Pretendard,"Apple SD Gothic Neo",Arial,sans-serif;background:#f5f6fa;display:flex;height:100vh;overflow:hidden;color:#07112d}.sidebar{width:220px;background:#1a2235;display:flex;flex-direction:column;height:100vh;flex-shrink:0}.sb-logo{padding:20px 18px 16px;border-bottom:1px solid rgba(255,255,255,.08)}.sb-logo-title{font-size:16px;font-weight:700;color:#fff}.sb-logo-title span{display:inline-block;width:3px;height:16px;background:#2d6be4;border-radius:2px;margin-right:8px;vertical-align:middle}.sb-logo-sub{font-size:11px;color:rgba(255,255,255,.4);margin-top:2px}.sb-logo-sub2{font-size:10px;color:rgba(255,255,255,.3);margin-top:3px}.sb-nav{padding:14px 10px;flex:1}.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;font-size:13px;color:rgba(255,255,255,.55);cursor:pointer;margin-bottom:2px}.nav-item.active,.nav-item:hover{background:rgba(255,255,255,.1);color:#fff}.nav-item i{font-size:17px}.sb-bottom{padding:14px 10px;border-top:1px solid rgba(255,255,255,.08)}.sb-user{display:flex;align-items:center;gap:10px;padding:10px 12px;margin-bottom:2px}.sb-avatar{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center}.sb-avatar i{font-size:15px;color:rgba(255,255,255,.7)}.sb-user-name{font-size:12px;font-weight:600;color:#fff}.sb-user-email{font-size:10px;color:rgba(255,255,255,.4);margin-top:1px}.sb-logout{display:flex;align-items:center;gap:10px;padding:9px 12px;font-size:13px;color:rgba(255,255,255,.4);cursor:pointer;border-radius:8px}.sb-logout:hover{color:#fff;background:rgba(255,255,255,.06)}.main{flex:1;display:flex;flex-direction:column;overflow:hidden}.topbar{height:60px;background:#fff;border-bottom:1px solid #e5e7eb;padding:0 24px;display:flex;align-items:center;justify-content:space-between}.topbar-title{font-size:20px;font-weight:800}.topbar-right{display:flex;align-items:center;gap:14px;font