{height:30px;min-width:48px;border:0;border-radius:7px;background:transparent;color:#8b98b2;font-size:12px;font-weight:700;cursor:pointer}.tab.active{background:#fff;color:#07112d;box-shadow:0 1px 5px rgba(15,23,42,.1)}.sensor-list{flex:1;overflow-y:auto;padding-right:6px;display:flex;flex-direction:column;gap:10px}.sensor-card{background:#fff;border:1px solid #e1e6ef;border-radius:12px;overflow:hidden;flex-shrink:0}.sensor-card.danger{border-color:#ff7a7a;background:#fff7f7}.sensor-card.warning{border-color:#f2bc1b;background:#fffdf1}.sensor-card.offline{border-color:#cbd5e1;background:#f8fafc}.card-top{height:48px;display:grid;grid-template-columns:52px 1fr 92px 28px;align-items:center;padding:0 18px}.sensor-id{font-size:13px;font-weight:900;color:#94a3b8}.sensor-id.danger{color:#dc2626}.sensor-id.offline{color:#64748b}.name{font-size:15px;font-weight:700;color:#07112d}.addr{font-size:12px;color:#8b98b2;margin-top:3px}.badge{justify-self:end;display:inline-flex;align-items:center;gap:5px;height:26px;padding:0 12px;border-radius:999px;font-size:12px;font-weight:700}.badge.danger{background:#fee2e2;color:#dc2626}.badge.warning{background:#fef3c7;color:#b45309}.badge.normal{background:#dcfce7;color:#15803d}.badge.offline{background:#e2e8f0;color:#475569}.chev{color:#9aa6bb;font-size:16px;justify-self:end}.card-body{display:none;border-top:1px solid #edf1f7}.sensor-card.open .card-body{display:grid;grid-template-columns:repeat(4,1fr);min-height:92px}.metric{display:flex;flex-direction:column;align-items:center;justify-content:center;border-right:1px solid #edf1f7}.metric:last-child{border-right:0}.metric-label{font-size:12px;color:#9aa6bb;margin-bottom:8px}.metric-value{font-size:18px;font-weight:700}.metric-value.danger{color:#dc2626}.metric-value.warning{color:#d97706}.metric-value.normal{color:#07112d}.metric-value.offline{color:#64748b}.unit{font-size:11px;color:#8b98b2;font-weight:500}.ai-box{grid-column:1/-1;margin:0 18px 12px;padding:12px 14px;border-radius:10px;background:#f8fafc;border:1px solid #e2e8f0;display:flex;align-items:flex-start;gap:10px}.sensor-card.danger .ai-box{background:#fff1f2;border-color:#fecdd3}.sensor-card.warning .ai-box{background:#fffbeb;border-color:#fde68a}.ai-icon{width:28px;height:28px;border-radius:50%;background:#eef3fd;color:#2563eb;display:grid;place-items:center;flex-shrink:0}.ai-title{font-size:12px;font-weight:900;color:#0f172a;margin-bottom:4px}.ai-reason{font-size:12px;color:#475569;line-height:1.5}.ai-meta{font-size:11px;color:#94a3b8;margin-top:5px}.card-foot{grid-column:1/-1;text-align:right;padding:0 18px 12px;color:#c3cad8;font-size:11px}.side{display:flex;flex-direction:column;gap:14px;min-height:0;overflow-y:auto}.side-card{background:#fff;border:1px solid #e1e6ef;border-radius:12px;padding:16px}.side-title{font-size:14px;font-weight:900;margin-bottom:14px}.calendar-head{display:flex;align-items:center;justify-content:space-between;color:#94a3b8}.calendar-title{font-size:13px;font-weight:900;color:#172033}.week{display:grid;grid-template-columns:repeat(7,1fr);text-align:center;font-size:11px;color:#8b98b2;margin-top:18px}.calendar-days{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-top:10px}.calendar-day{height:28px;border:0;border-radius:7px;background:#fff;color:#64748b;font-size:12px;cursor:pointer}.calendar-day:hover,.calendar-day.active{background:#2563eb;color:#fff;font-weight:800}.record-empty{height:70px;display:flex;align-items:center;justify-content:center;color:#a7b0c2;font-size:12px}.event{display:flex;gap:8px;padding:9px 0;border-bottom:1px solid #f1f4f8}.dot{width:8px;height:8px;border-radius:50%;margin-top:5px}.dot.danger{background:#dc2626}.dot.warning{background:#d97706}.dot.normal{background:#16a34a}.event-title{font-size:12px;font-weight:800}.event-title.danger{color:#dc2626}.event-title.warning{color:#d97706}.event-title.normal{color:#16a34a}.event-desc,.event-time{font-size:11px;color:#94a3b8}.alert-area{position:relative}.alert-button{position:relative;width:38px;height:38px;border:1px solid #e5e7eb;border-radius:50%;background:#fff;cursor:pointer;font-size:17px;display:grid;place-items:center}.alert-dot{position:absolute;top:7px;right:8px;width:8px;height:8px;background:#ef4444;border-radius:50%;border:2px solid #fff}.alert-dot.hide{display:none}.alert-dropdown{display:none;position:absolute;top:46px;right:0;width:330px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 18px 45px rgba(15,23,42,.18);overflow:hidden;z-index:50}.alert-dropdown.open{display:block}.alert-head{display:flex;justify-content:space-between;padding:16px 18px;border-bottom:1px solid #eef2f7}.alert-head button,.alert-more{border:0;background:#fff;color:#2563eb;cursor:pointer}.alert-list{max-height:300px;overflow-y:auto}.alert-item{display:grid;grid-template-columns:42px 1fr 56px;gap:10px;padding:14px 16px;border-bottom:1px solid #f1f5f9}.alert-item.danger{background:#fff5f5}.alert-icon{width:34px;height:34px;border-radius:50%;display:grid;place-items:center}.alert-item.danger .alert-icon{background:#fee2e2;color:#ef4444}.alert-item.warning .alert-icon{background:#fef3c7;color:#f59e0b}.alert-item.normal .alert-icon{background:#d1fae5;color:#10b981}.alert-text{display:flex;flex-direction:column;gap:4px}.alert-text strong{font-size:14px}.alert-text span{font-size:13px}.alert-text small,.alert-time{font-size:12px;color:#9ca3af}.alert-more{width:100%;height:42px;font-weight:700}.all-alert-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:9000;align-items:center;justify-content:center}.all-alert-overlay.open{display:flex}.all-alert-modal{width:720px;max-height:80vh;background:#fff;border-radius:16px;box-shadow:0 24px 70px rgba(15,23,42,.25);overflow:hidden}.all-alert-header{display:flex;justify-content:space-between;padding:22px 24px;border-bottom:1px solid #e5e7eb}.all-alert-header button{width:36px;height:36px;border:0;border-radius:50%;font-size:24px}.all-alert-list{max-height:58vh;overflow:auto;padding:10px}.all-alert-row{display:grid;grid-template-columns:180px 1fr 90px;gap:16px;padding:16px;border-bottom:1px solid #f1f5f9}.all-alert-row.danger{background:#fff5f5}.all-alert-row.warning{background:#fffbeb}.all-alert-row.normal{background:#ecfdf5}
