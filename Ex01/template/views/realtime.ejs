</style></head><body>
<div class="sidebar"><div class="sb-logo"><div class="sb-logo-title"><span></span>FIDS</div><div class="sb-logo-sub2">쓰레기통 화재 감지 시스템</div><div class="sb-logo-sub">관리자 대시보드</div></div><div class="sb-nav"><div class="nav-item" onclick="location.href='/dashboard'"><i class="ti ti-home"></i>대시보드</div><div class="nav-item" onclick="location.href='/trashbins'"><i class="ti ti-trash"></i>쓰레기통 관리</div><div class="nav-item active" onclick="location.href='/realtime'"><i class="ti ti-chart-line"></i>실시간 모니터링</div><div class="nav-item" onclick="location.href='/alert'"><i class="ti ti-bell"></i>알림 기록</div><div class="nav-item operator-menu" onclick="location.href='/admin/approval'"><i class="ti ti-user-check"></i>관리자 승인 관리</div><div class="nav-item" onclick="location.href='/settings'"><i class="ti ti-settings"></i>설정</div><div class="nav-item" onclick="location.href='/'"><i class="ti ti-home-2"></i>메인페이지</div></div><div class="sb-bottom"><div class="sb-user"><div class="sb-avatar"><i class="ti ti-user"></i></div><div><div id="userName" class="sb-user-name">관리자</div><div id="userEmail" class="sb-user-email">admin@korea.kr</div></div></div><div id="logoutBtn" class="sb-logout"><i class="ti ti-logout"></i>로그아웃</div></div></div>
<div class="main"><div class="topbar"><div class="topbar-title">실시간 모니터링</div><div class="topbar-right"><span class="live-dot">LIVE</span><span>·</span><i class="ti ti-calendar"></i><span id="nowText"></span><div class="alert-area"><button class="alert-button" id="alertButton"><i class="ti ti-bell"></i><span class="alert-dot" id="alertDot"></span></button><div class="alert-dropdown" id="alertDropdown"><div class="alert-head"><strong>알림</strong><button id="readAllBtn">모두 읽음</button></div><div class="alert-list" id="alertList"></div><button class="alert-more" id="openAllAlertsBtn">전체 알림 보기 →</button></div></div></div></div>
<div class="content"><div class="stat-row"><div class="stat-card" onclick="setStatusFilter('')"><div class="stat-icon" style="background:#eff6ff;color:#3b82f6"><i class="ti ti-map-pin"></i></div><div><div class="stat-num" id="totalCount">0</div><div class="stat-lbl">등록된 설치 위치</div></div></div><div class="stat-card" onclick="setStatusFilter('danger')"><div class="stat-icon" style="background:#fee2e2;color:#dc2626"><i class="ti ti-flame"></i></div><div><div class="stat-num" id="dangerCount" style="color:#dc2626">0</div><div class="stat-lbl">위험 경보</div></div></div><div class="stat-card" onclick="setStatusFilter('warning')"><div class="stat-icon" style="background:#fef3c7;color:#d97706"><i class="ti ti-alert-triangle"></i></div><div><div class="stat-num" id="warningCount" style="color:#d97706">0</div><div class="stat-lbl">주의 감지</div></div></div><div class="stat-card" onclick="setStatusFilter('normal')"><div class="stat-icon" style="background:#dcfce7;color:#16a34a"><i class="ti ti-check"></i></div><div><div class="stat-num" id="normalCount" style="color:#16a34a">0</div><div class="stat-lbl">정상 운영 중</div></div></div></div><div class="info-banner"><i class="ti ti-info-circle"></i><p>설치 위치는 관리자가 <b>쓰레기통 관리</b> 메뉴에서 등록한 주소 기준으로 표시됩니다. 실제 GPS 위치가 아닌 등록된 설치 주소를 기준으로 센서 데이터를 매핑합니다.</p></div><div class="body-wrap"><section class="sensor-panel"><div class="sensor-head"><div><div class="sensor-title">설치 위치별 센서 현황</div><div class="sensor-sub" id="listSub">센서 데이터 로딩 중</div></div><input type="hidden" id="statusFilter" value=""></div><div class="tabs"><button class="tab active" data-type="" onclick="setStatusFilter('')">전체</button><button class="tab" data-type="danger" onclick="setStatusFilter('danger')">위험</button><button class="tab" data-type="warning" onclick="setStatusFilter('warning')">주의</button><button class="tab" data-type="normal" onclick="setStatusFilter('normal')">정상</button></div><div class="sensor-list" id="sensorList"></div></section></div></div></div>
<div class="all-alert-overlay" id="allAlertOverlay"><div class="all-alert-modal"><div class="all-alert-header"><div><h2>전체 알림</h2><p>최근 감지된 알림 내역입니다.</p></div><button id="closeAllAlertsBtn">×</button></div><div class="all-alert-list" id="allAlertList"></div></div></div>
<script>
const els={
  userName:document.getElementById("userName"),userEmail:document.getElementById("userEmail"),logoutBtn:document.getElementById("logoutBtn"),nowText:document.getElementById("nowText"),statusFilter:document.getElementById("statusFilter"),totalCount:document.getElementById("totalCount"),dangerCount:document.getElementById("dangerCount"),warningCount:document.getElementById("warningCount"),normalCount:document.getElementById("normalCount"),listSub:document.getElementById("listSub"),sensorList:document.getElementById("sensorList"),alertButton:document.getElementById("alertButton"),alertDot:document.getElementById("alertDot"),alertDropdown:document.getElementById("alertDropdown"),alertList:document.getElementById("alertList"),readAllBtn:document.getElementById("readAllBtn"),openAllAlertsBtn:document.getElementById("openAllAlertsBtn"),allAlertOverlay:document.getElementById("allAlertOverlay"),allAlertList:document.getElementById("allAlertList"),closeAllAlertsBtn:document.getElementById("closeAllAlertsBtn")
};
let sensors=[],alerts=[],smokeHistory=[],opened=new Set();
let smokeThresholds={dangerSmoke:230,warningSmoke:150};
const params=new URLSearchParams(location.search);const initialGun=params.get("gun")||params.get("district")||"";
const role=sessionStorage.getItem("role"),mgrName=sessionStorage.getItem("mgr_name"),mgrEmail=sessionStorage.getItem("mgr_email");
if(!role){alert("로그인이 필요합니다.");location.href="/login";}
els.userName.textContent=mgrName||"관리자";els.userEmail.textContent=mgrEmail||"";
els.logoutBtn.onclick=function(){sessionStorage.clear();alert("로그아웃되었습니다.");location.replace("/");};
function tick(){const n=new Date();const w=["일","월","화","수","목","금","토"][n.getDay()];els.nowText.textContent=n.getFullYear()+"."+String(n.getMonth()+1).padStart(2,"0")+"."+String(n.getDate()).padStart(2,"0")+" ("+w+") "+String(n.getHours()).padStart(2,"0")+":"+String(n.getMinutes()).padStart(2,"0")+":"+String(n.getSeconds()).padStart(2,"0");}
function displayBinId(row){const id=row&&row.display_bin_id!=null?row.display_bin_id:row&&row.bin_id;return String(id||"").padStart(2,"0");}
function statusOf(r){if(String(r.sensor_online||"")==="N"||Number(r.network_status)===0)return"offline";if(r.alert_type==="danger")return"danger";if(r.alert_type==="warning")return"warning";return"normal";}
function statusText(s){return s==="danger"?"위험":s==="warning"?"주의":s==="offline"?"오프라인":"정상";}
function rank(s){return s==="danger"?1:s==="warning"?2:s==="normal"?3:4;}
function ftime(v){return v?new Date(v).toLocaleTimeString("ko-KR",{hour:"2-digit",minute:"2-digit",second:"2-digit"}):"-";}
function splitRegion(loc){const p=String(loc||"").trim().split(/\s+/);return{city:p[0]||"기타",gun:p[1]||"미분류"};}
function enrich(r){const rg=splitRegion(r.bin_loc);return Object.assign({},r,{city:rg.city,gun:rg.gun});}
function temp(r){if(r.temp_value!=null&&r.temp_value!=="")return Number(r.temp_value).toFixed(1);const m=String(r.alert_msg||"").match(/온도\s*([0-9.]+)/);return m?Number(m[1]).toFixed(1):"-";}
function smoke(r){if(r.smoke_value!=null&&r.smoke_value!=="")return Number(r.smoke_value);const m=String(r.alert_msg||"").match(/연기\s*감지값\s*(\d+(?:\.\d+)?)/);return m?Number(m[1]):"-";}
function flame(r){if(r.flame_value!=null&&r.flame_value!=="")return Number(r.flame_value)===1?"O":"X";const m=String(r.alert_msg||"").match(/불꽃\s*감지\s*(0|1|O|X)/i);if(!m)return"-";const v=String(m[1]).toUpperCase();return v==="1"||v==="O"?"O":"X";}
function wifi(r){if(statusOf(r)==="offline")return"-";const sm=Number(smoke(r));return Number.isFinite(sm)?Math.max(-79,Math.min(-49,-48-Math.round(sm/11))):"-";}
function aiReason(r){return r.ai_reason||"센서값이 현재 상태 기준과 일치합니다.";}
function aiSummary(r){return "AI 판단: "+statusText(r.ai_status||statusOf(r));}
function isAiEnabled(r){return r&&(r.ai_enabled==="Y"||r.ai_enabled===true||r.ai_enabled===1||r.ai_enabled==="1");}
function setStatusFilter(t){els.statusFilter.value=t;document.querySelectorAll(".tab").forEach(function(b){b.classList.toggle("active",b.dataset.type===t);});renderSensors();}
function toggleOpen(id){id=String(id);opened.has(id)?opened.delete(id):opened.add(id);renderSensors();}
function visibleSensorRows(){const sf=els.statusFilter.value;return sensors.filter(function(r){const st=statusOf(r);return(!sf||st===sf)&&(!initialGun||r.gun===initialGun);}).sort(function(a,b){return rank(statusOf(a))-rank(statusOf(b))||Number(a.bin_id)-Number(b.bin_id);});}
function smokeTrendSvg(target){
  const danger=Number(smokeThresholds.dangerSmoke)||230,warning=Number(smokeThresholds.warningSmoke)||150;
  const w=286,h=104,ox=26,oy=8,axisMin=0,axisMax=500,targetId=target?Number(target.bin_id):0;
  const rows=smokeHistory.filter(function(r){return Number(r.bin_id)===targetId;}).sort(function(a,b){return new Date(a.sensed_at||a.created_at||a.alerted_at||a.received_at||0)-new Date(b.sensed_at||b.created_at||b.alerted_at||b.received_at||0);}).slice(-12);
  let vals=rows.map(function(r){return Number(r.gas);}).filter(function(v){return Number.isFinite(v);});
  if(!target||statusOf(target)==="offline"||!vals.length)vals=Array(12).fill(0);
  const clamp=function(v){return Math.max(axisMin,Math.min(axisMax,Number(v)||0));};
  const y=function(v){return oy+h-((clamp(v)-axisMin)/(axisMax-axisMin))*h;};
  const x=function(i){return ox+(vals.length===1?w:(w/(vals.length-1))*i);};
  const ticks=[0,100,200,300,400,500];
  const grid=ticks.map(function(t){return '<line class="rt-axis" x1="'+ox+'" y1="'+y(t)+'" x2="'+(ox+w)+'" y2="'+y(t)+'"></line><text class="rt-label" x="'+(ox-8)+'" y="'+(y(t)+3)+'" text-anchor="end">'+t+'</text>';}).join("");
  const points=vals.map(function(v,i){return x(i)+','+y(v);}).join(" ");
  const area=ox+','+(oy+h)+' '+points+' '+(ox+w)+','+(oy+h);
  const currentLabel=target&&statusOf(target)!=="offline"?smoke(target):0;
  const circles=vals.map(function(v,i){return '<circle class="rt-point" cx="'+x(i)+'" cy="'+y(v)+'" r="3"></circle>';}).join("");
  return grid+'<line class="rt-axis" x1="'+ox+'" y1="'+(oy+h)+'" x2="'+(ox+w)+'" y2="'+(oy+h)+'"></line><line class="rt-warning" x1="'+ox+'" y1="'+y(warning)+'" x2="'+(ox+w)+'" y2="'+y(warning)+'"></line><line class="rt-danger" x1="'+ox+'" y1="'+y(danger)+'" x2="'+(ox+w)+'" y2="'+y(danger)+'"></line><text class="rt-danger-label" x="'+(ox+w-34)+'" y="'+Math.max(8,y(danger)-14)+'">위험 '+danger+'</text><text class="rt-warning-label" x="'+(ox+w-34)+'" y="'+Math.max(22,y(warning)-5)+'">주의 '+warning+'</text><polygon class="rt-area" points="'+area+'"></polygon><polyline class="rt-line" points="'+points+'"></polyline>'+circles+'<text class="rt-label" x="'+(ox+w)+'" y="'+(oy+h+12)+'" text-anchor="end">현재 '+currentLabel+'</text>';
}
function smokeTrendBlock(row){return '<div class="inline-trend-card"><div class="inline-trend-head"><div class="inline-trend-title">연기감지값 추이</div></div><svg class="inline-smoke-chart" viewBox="0 0 320 126" preserveAspectRatio="none">'+smokeTrendSvg(row)+'</svg></div>';}
async function loadRealtimeThresholds(){try{const r=await fetch("/settings/api/thresholds");const j=await r.json();if(j.success&&j.thresholds){smokeThresholds.dangerSmoke=Number(j.thresholds.dangerSmoke)||230;smokeThresholds.warningSmoke=Number(j.thresholds.warningSmoke)||150;}}catch(e){}}
function renderStats(){const total=sensors.length,d=sensors.filter(function(s){return statusOf(s)==="danger";}).length,w=sensors.filter(function(s){return statusOf(s)==="warning";}).length,n=sensors.filter(function(s){return statusOf(s)==="normal";}).length,o=sensors.filter(function(s){return statusOf(s)==="offline";}).length;els.totalCount.textContent=total;els.dangerCount.textContent=d;els.warningCount.textContent=w;els.normalCount.textContent=n;els.listSub.textContent='총 '+total+'개 센서 · 위험 '+d+'개 · 주의 '+w+'개 · 정상 '+n+'개 · 오프라인 '+o+'개';}
function renderSensors(){const rows=visibleSensorRows();els.sensorList.innerHTML=rows.map(function(r){const st=statusOf(r),tm=temp(r),sm=smoke(r),fl=flame(r),wf=wifi(r),open=opened.has(String(r.bin_id));return '<article class="sensor-card '+st+' '+(open?'open':'')+'" title="'+(st==='offline'?'오프라인 상태입니다.':(r.ai_reason||''))+'"><div class="card-top" onclick="toggleOpen('+r.bin_id+')"><span class="sensor-id '+st+'">#'+displayBinId(r)+'</span><div><div class="name">'+(r.bin_loc||'-')+'</div><div class="addr">'+(r.city||'')+' '+(r.gun||'')+'</div></div><span class="badge '+st+'"><i class="ti '+(st==='danger'?'ti-flame':st==='warning'?'ti-alert-triangle':st==='offline'?'ti-wifi-off':'ti-check')+'"></i>'+statusText(st)+'</span><i class="chev ti '+(open?'ti-chevron-up':'ti-chevron-down')+'"></i></div><div class="card-body"><div class="metric"><div class="metric-label">온도</div><div class="metric-value '+st+'">'+tm+'<span class="unit"> ℃</span></div></div><div class="metric"><div class="metric-label">연기감지값</div><div class="metric-value '+st+'">'+sm+'</div></div><div class="metric"><div class="metric-label">불꽃 감지</div><div class="metric-value '+st+'">'+fl+'</div></div><div class="metric"><div class="metric-label">Wi-Fi</div><div class="metric-value '+st+'">'+wf+(wf==='-'?'':' dBm')+'</div></div>'+(open?smokeTrendBlock(r):'')+(isAiEnabled(r)&&st!=='offline'?'<div class="ai-box"><div class="ai-icon"><i class="ti ti-sparkles"></i></div><div><div class="ai-title">AI 판단</div><div class="ai-reason">'+aiReason(r)+'</div><div class="ai-meta">'+aiSummary(r)+'</div></div></div>':'')+'<div class="card-foot">마지막 수신: '+ftime(r.alerted_at)+'</div></div></article>';}).join("")||'<div class="side-card" style="text-align:center;color:#94a3b8">조건에 맞는 센서가 없습니다.</div>';renderStats();}
function atitle(t){return t==="danger"?"위험 감지":t==="warning"?"주의 감지":"정상";}
function aicon(t){return t==="danger"?"ti-flame":t==="warning"?"ti-alert-triangle":"ti-check";}
function renderAlerts(){const dangerAlerts=alerts.filter(function(a){return a.alert_type==="danger";});els.alertDot.classList.toggle("hide",!dangerAlerts.some(function(a){return a.is_received!=="Y";}));els.alertList.innerHTML=dangerAlerts.slice(0,5).map(function(a){return '<div class="alert-item '+a.alert_type+'"><div class="alert-icon"><i class="ti '+aicon(a.alert_type)+'"></i></div><div class="alert-text"><strong>'+atitle(a.alert_type)+'</strong><span>#'+displayBinId(a)+' '+(a.bin_loc||'')+'</span><small>'+(a.alert_msg||'센서 상태 확인')+'</small></div><span class="alert-time">'+ftime(a.alerted_at)+'</span></div>';}).join("")||'<div style="padding:28px;text-align:center;color:#94a3b8">표시할 위험 알림이 없습니다.</div>';els.allAlertList.innerHTML=dangerAlerts.map(function(a){return '<div class="all-alert-row '+a.alert_type+'"><div><strong>'+atitle(a.alert_type)+'</strong><span>#'+displayBinId(a)+' '+(a.bin_loc||'')+'</span></div><p>'+(a.alert_msg||'센서 상태 확인')+'</p><time>'+ftime(a.alerted_at)+'</time></div>';}).join("");}
async function loadRealtimeData(){await loadRealtimeThresholds();try{const br=await fetch("/trashbins/list");const ar=await fetch("/alerts/list");const hr=await fetch("/trashbins/sensor-history");sensors=(await br.json()).map(enrich);alerts=await ar.json();const h=await hr.json();smokeHistory=Array.isArray(h)?h:[];renderSensors();renderAlerts();}catch(e){els.sensorList.innerHTML='<div class="side-card" style="text-align:center;color:#ef4444">실시간 데이터를 불러오지 못했습니다.</div>';}}
els.alertButton.onclick=function(e){e.stopPropagation();els.alertDropdown.classList.toggle("open");};
els.readAllBtn.onclick=async function(){await fetch("/alerts/read-all",{method:"POST"});await loadRealtimeData();};
els.openAllAlertsBtn.onclick=function(){els.alertDropdown.classList.remove("open");els.allAlertOverlay.classList.add("open");};
els.closeAllAlertsBtn.onclick=function(){els.allAlertOverlay.classList.remove("open");};
document.onclick=function(e){if(!e.target.closest(".alert-area"))els.alertDropdown.classList.remove("open");};
tick();setInterval(tick,1000);loadRealtimeData();setInterval(loadRealtimeData,3000);
</script><script src="/js/fire-alert.js"></script>
